{"stream": "stderr", "line": "+  private async listPages<T>(pathForPage: (page: number) => string): Promise<T[]> {"}
{"stream": "stderr", "line": "+    const results: T[] = [];"}
{"stream": "stderr", "line": "+    let page = 1;"}
{"stream": "stderr", "line": "+    let hasNext = true;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    while (hasNext) {"}
{"stream": "stderr", "line": "+      const response = await this.rawRequest<T[]>(pathForPage(page));"}
{"stream": "stderr", "line": "+      results.push(...response.data);"}
{"stream": "stderr", "line": "+      hasNext = hasNextPage(response.response, response.data.length);"}
{"stream": "stderr", "line": "+      page += 1;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    return results;"}
{"stream": "stderr", "line": "+  }"}
