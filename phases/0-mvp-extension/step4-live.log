{"stream": "stderr", "line": "+async function githubRequest<T>("}
{"stream": "stderr", "line": "+  auth: GitHubAuthContext,"}
{"stream": "stderr", "line": "+  path: string,"}
{"stream": "stderr", "line": "+  init: RequestInit = {}"}
{"stream": "stderr", "line": "+): Promise<{ data: T; response: Response }> {"}
{"stream": "stderr", "line": "+  if (auth.pat.trim().length === 0) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError(\"github_auth_failed\", \"GitHub PAT is required.\");"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  let response: Response;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    response = await auth.fetchImpl(buildApiUrl(auth.apiBaseUrl, path), {"}
{"stream": "stderr", "line": "+      ...init,"}
{"stream": "stderr", "line": "+      headers: buildHeaders(auth.pat, init)"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    throw normalizeError(error);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const text = await response.text();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!response.ok) {"}
{"stream": "stderr", "line": "+    const message = parseErrorMessage(text) ?? response.statusText;"}
{"stream": "stderr", "line": "+    throw new GitHubHttpError("}
{"stream": "stderr", "line": "+      response.status,"}
{"stream": "stderr", "line": "+      message,"}
{"stream": "stderr", "line": "+      inferResponseErrorCode(response, message)"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (response.status === 204 || text.trim().length === 0) {"}
{"stream": "stderr", "line": "+    return {"}
{"stream": "stderr", "line": "+      data: undefined as T,"}
{"stream": "stderr", "line": "+      response"}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    data: JSON.parse(text) as T,"}
{"stream": "stderr", "line": "+    response"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function buildHeaders(pat: string, init: RequestInit): Headers {"}
{"stream": "stderr", "line": "+  const headers = new Headers(init.headers);"}
{"stream": "stderr", "line": "+  headers.set(\"Accept\", \"application/vnd.github+json\");"}
{"stream": "stderr", "line": "+  headers.set(\"Authorization\", `Bearer ${pat}`);"}
{"stream": "stderr", "line": "+  headers.set(\"X-GitHub-Api-Version\", GITHUB_API_VERSION);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (init.body !== undefined && !headers.has(\"Content-Type\")) {"}
{"stream": "stderr", "line": "+    headers.set(\"Content-Type\", \"application/json\");"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return headers;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function buildApiUrl(apiBaseUrl: string, path: string): string {"}
{"stream": "stderr", "line": "+  return new URL(path, apiBaseUrl).toString();"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function hasNextPage(response: Response, itemCount: number): boolean {"}
{"stream": "stderr", "line": "+  const link = response.headers.get(\"Link\");"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (link !== null) {"}
{"stream": "stderr", "line": "+    return link.split(\",\").some((part) => /;\\s*rel=\"next\"\\s*$/u.test(part.trim()));"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return itemCount === PAGE_SIZE;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function parseErrorMessage(text: string): string | null {"}
{"stream": "stderr", "line": "+  if (text.trim().length === 0) {"}
{"stream": "stderr", "line": "+    return null;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    const parsed = JSON.parse(text) as unknown;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (isRecord(parsed) && typeof parsed.message === \"string\") {"}
{"stream": "stderr", "line": "+      return parsed.message;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch {"}
{"stream": "stderr", "line": "+    return text;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return text;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function inferResponseErrorCode("}
{"stream": "stderr", "line": "+  response: Response,"}
{"stream": "stderr", "line": "+  message: string"}
{"stream": "stderr", "line": "+): NormalizedErrorCode | undefined {"}
{"stream": "stderr", "line": "+  const normalizedMessage = message.toLowerCase();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if ("}
{"stream": "stderr", "line": "+    response.status === 429 ||"}
{"stream": "stderr", "line": "+    response.headers.get(\"X-RateLimit-Remaining\") === \"0\" ||"}
{"stream": "stderr", "line": "+    normalizedMessage.includes(\"rate limit\")"}
{"stream": "stderr", "line": "+  ) {"}
{"stream": "stderr", "line": "+    return \"github_rate_limited\";"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (response.status === 403 && normalizedMessage.includes(\"protected\")) {"}
{"stream": "stderr", "line": "+    return \"github_branch_protected\";"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (response.status === 401 && normalizedMessage.includes(\"expired\")) {"}
{"stream": "stderr", "line": "+    return \"github_token_expired\";"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return undefined;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function normalizeBranchCreateError(error: unknown): NormalizedError {"}
{"stream": "stderr", "line": "+  const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if ("}
{"stream": "stderr", "line": "+    normalized.code === \"github_auth_failed\" ||"}
{"stream": "stderr", "line": "+    normalized.code === \"github_token_expired\" ||"}
{"stream": "stderr", "line": "+    normalized.code === \"github_rate_limited\" ||"}
{"stream": "stderr", "line": "+    normalized.code === \"github_repo_not_found\" ||"}
{"stream": "stderr", "line": "+    normalized.code === \"github_default_branch_unavailable\""}
{"stream": "stderr", "line": "+  ) {"}
{"stream": "stderr", "line": "+    return normalized;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return normalizeError({"}
{"stream": "stderr", "line": "+    code: \"github_branch_create_failed\","}
{"stream": "stderr", "line": "+    message: normalized.debugMessage ?? normalized.userMessage"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function explicitNormalizedError("}
