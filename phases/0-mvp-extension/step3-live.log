{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function readState<T>("}
{"stream": "stderr", "line": "+  area: StorageAreaAdapter,"}
{"stream": "stderr", "line": "+  key: StorageKey,"}
{"stream": "stderr", "line": "+  fallback: T,"}
{"stream": "stderr", "line": "+  guard: (value: unknown) => value is T"}
{"stream": "stderr", "line": "+): Promise<T> {"}
{"stream": "stderr", "line": "+  const values = await area.get([key]);"}
{"stream": "stderr", "line": "+  const value = values[key];"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return guard(value) ? cloneState(value) : cloneState(fallback);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function writeState<T>("}
{"stream": "stderr", "line": "+  area: StorageAreaAdapter,"}
{"stream": "stderr", "line": "+  key: StorageKey,"}
{"stream": "stderr", "line": "+  state: T"}
{"stream": "stderr", "line": "+): Promise<T> {"}
{"stream": "stderr", "line": "+  await area.set({ [key]: state });"}
{"stream": "stderr", "line": "+  return cloneState(state);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function isSameIdentity(left: SubmissionIdentity, right: SubmissionIdentity): boolean {"}
{"stream": "stderr", "line": "+  return ("}
{"stream": "stderr", "line": "+    left.submissionId === right.submissionId &&"}
{"stream": "stderr", "line": "+    left.titleSlug === right.titleSlug &&"}
{"stream": "stderr", "line": "+    left.language === right.language"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function capRetryPayloads(payloads: RetryPayload[]): RetryPayload[] {"}
{"stream": "stderr", "line": "+  return [...payloads]"}
{"stream": "stderr", "line": "+    .sort((left, right) => compareIsoDescending(left.createdAt, right.createdAt))"}
{"stream": "stderr", "line": "+    .slice(0, RETRY_PAYLOAD_LIMIT);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function normalizeRetryPayloadTtl(payload: RetryPayload): RetryPayload {"}
{"stream": "stderr", "line": "+  const createdAt = parseTimestamp(payload.createdAt);"}
{"stream": "stderr", "line": "+  const expiresAt = parseTimestamp(payload.expiresAt);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (createdAt === null) {"}
{"stream": "stderr", "line": "+    return payload;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const latestAllowedExpiresAt = createdAt + RETRY_PAYLOAD_TTL_MS;"}
{"stream": "stderr", "line": "+  const nextExpiresAt ="}
{"stream": "stderr", "line": "+    expiresAt === null || expiresAt > latestAllowedExpiresAt"}
{"stream": "stderr", "line": "+      ? new Date(latestAllowedExpiresAt).toISOString()"}
{"stream": "stderr", "line": "+      : payload.expiresAt;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    ...payload,"}
{"stream": "stderr", "line": "+    expiresAt: nextExpiresAt"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function pruneRetryPayloadList("}
{"stream": "stderr", "line": "+  payloads: RetryPayload[],"}
{"stream": "stderr", "line": "+  now: Date | IsoDateString | number"}
{"stream": "stderr", "line": "+): RetryPayload[] {"}
{"stream": "stderr", "line": "+  const nowTimestamp = toTimestamp(now);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return payloads.filter((payload) => {"}
{"stream": "stderr", "line": "+    const createdAt = parseTimestamp(payload.createdAt);"}
{"stream": "stderr", "line": "+    const expiresAt = parseTimestamp(payload.expiresAt);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (createdAt === null || expiresAt === null) {"}
{"stream": "stderr", "line": "+      return false;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    return nowTimestamp < expiresAt && nowTimestamp < createdAt + RETRY_PAYLOAD_TTL_MS;"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function pruneInFlightLockList("}
{"stream": "stderr", "line": "+  locks: InFlightSyncsState[\"locks\"],"}
{"stream": "stderr", "line": "+  now: Date | IsoDateString | number"}
{"stream": "stderr", "line": "+): InFlightSyncsState[\"locks\"] {"}
{"stream": "stderr", "line": "+  const nowTimestamp = toTimestamp(now);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return locks.filter((lock) => {"}
{"stream": "stderr", "line": "+    const lockedAt = parseTimestamp(lock.lockedAt);"}
{"stream": "stderr", "line": "+    const expiresAt = parseTimestamp(lock.expiresAt);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (lockedAt === null || expiresAt === null) {"}
{"stream": "stderr", "line": "+      return false;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    return nowTimestamp < expiresAt && nowTimestamp < lockedAt + IN_FLIGHT_LOCK_TTL_MS;"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function compareIsoDescending(left: IsoDateString, right: IsoDateString): number {"}
{"stream": "stderr", "line": "+  const leftTimestamp = parseTimestamp(left) ?? 0;"}
{"stream": "stderr", "line": "+  const rightTimestamp = parseTimestamp(right) ?? 0;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return rightTimestamp - leftTimestamp;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function toIsoDateString(value: Date | IsoDateString | number): IsoDateString {"}
{"stream": "stderr", "line": "+  if (value instanceof Date) {"}
{"stream": "stderr", "line": "+    return value.toISOString();"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (typeof value === \"number\") {"}
{"stream": "stderr", "line": "+    return new Date(value).toISOString();"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return value;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function toTimestamp(value: Date | IsoDateString | number): number {"}
{"stream": "stderr", "line": "+  if (value instanceof Date) {"}
{"stream": "stderr", "line": "+    return value.getTime();"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (typeof value === \"number\") {"}
{"stream": "stderr", "line": "+    return value;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return parseTimestamp(value) ?? Date.now();"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function parseTimestamp(value: IsoDateString): number | null {"}
{"stream": "stderr", "line": "+  const timestamp = Date.parse(value);"}
{"stream": "stderr", "line": "+  return Number.isFinite(timestamp) ? timestamp : null;"}
{"stream": "stderr", "line": "+}"}
