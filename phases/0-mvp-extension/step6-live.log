{"stream": "stderr", "line": "+function filterRepositories("}
{"stream": "stderr", "line": "+  repositories: RepositoryRef[],"}
{"stream": "stderr", "line": "+  query: string | null"}
{"stream": "stderr", "line": "+): RepositoryRef[] {"}
{"stream": "stderr", "line": "+  const normalized = query?.trim().toLowerCase();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (normalized === undefined || normalized.length === 0) {"}
{"stream": "stderr", "line": "+    return repositories;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return repositories.filter((repository) =>"}
{"stream": "stderr", "line": "+    repository.fullName.toLowerCase().includes(normalized)"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+}"}
