{"stream": "stderr", "line": "+async function withGitHubClient<T>("}
{"stream": "stderr", "line": "+  context: {"}
{"stream": "stderr", "line": "+    storage: ExtensionStorage;"}
{"stream": "stderr", "line": "+    githubClientFactory: (pat: string) => GitHubClient;"}
{"stream": "stderr", "line": "+  },"}
{"stream": "stderr", "line": "+  operation: (client: GitHubClient) => Promise<T>"}
{"stream": "stderr", "line": "+): Promise<T> {"}
{"stream": "stderr", "line": "+  const settings = await context.storage.getSettings();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (settings.githubPat === null || settings.githubPat.trim().length === 0) {"}
{"stream": "stderr", "line": "+    throw explicitError(\"github_auth_failed\", \"GitHub PAT is required.\");"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return operation(context.githubClientFactory(settings.githubPat));"}
{"stream": "stderr", "line": "+}"}
