{"stream": "stderr", "line": "+function createChromeBroadcast(): SyncBroadcast {"}
{"stream": "stderr", "line": "+  return async (message, target) => {"}
{"stream": "stderr", "line": "+    await sendRuntimeMessage(message);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (target?.tabId !== undefined && chrome.tabs?.sendMessage !== undefined) {"}
{"stream": "stderr", "line": "+      await sendTabMessage(target.tabId, message);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function sendRuntimeMessage(message: RuntimeMessage): Promise<void> {"}
{"stream": "stderr", "line": "+  return new Promise((resolve) => {"}
{"stream": "stderr", "line": "+    chrome.runtime.sendMessage(message, () => {"}
{"stream": "stderr", "line": "+      void chrome.runtime.lastError;"}
{"stream": "stderr", "line": "+      resolve();"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function sendTabMessage(tabId: number, message: RuntimeMessage): Promise<void> {"}
{"stream": "stderr", "line": "+  return new Promise((resolve) => {"}
{"stream": "stderr", "line": "+    chrome.tabs.sendMessage(tabId, message, () => {"}
{"stream": "stderr", "line": "+      void chrome.runtime.lastError;"}
{"stream": "stderr", "line": "+      resolve();"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
