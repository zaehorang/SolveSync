{"stream": "stderr", "line": "+function toConnectionStatusCode(code: NormalizedErrorCode): ConnectionStatusCode {"}
{"stream": "stderr", "line": "+  switch (code) {"}
{"stream": "stderr", "line": "+    case \"github_no_accessible_repos\":"}
{"stream": "stderr", "line": "+      return \"no_accessible_repositories\";"}
{"stream": "stderr", "line": "+    case \"github_repo_not_found\":"}
{"stream": "stderr", "line": "+      return \"repository_not_found\";"}
{"stream": "stderr", "line": "+    case \"github_branch_not_found\":"}
{"stream": "stderr", "line": "+    case \"github_default_branch_unavailable\":"}
{"stream": "stderr", "line": "+      return \"branch_not_found\";"}
{"stream": "stderr", "line": "+    case \"github_branch_create_failed\":"}
{"stream": "stderr", "line": "+      return \"branch_create_failed\";"}
{"stream": "stderr", "line": "+    case \"github_auth_failed\":"}
{"stream": "stderr", "line": "+      return \"auth_failed\";"}
{"stream": "stderr", "line": "+    case \"github_token_expired\":"}
{"stream": "stderr", "line": "+      return \"token_expired\";"}
{"stream": "stderr", "line": "+    case \"github_rate_limited\":"}
{"stream": "stderr", "line": "+      return \"rate_limited\";"}
{"stream": "stderr", "line": "+    case \"network_failed\":"}
{"stream": "stderr", "line": "+      return \"network_failed\";"}
{"stream": "stderr", "line": "+    default:"}
