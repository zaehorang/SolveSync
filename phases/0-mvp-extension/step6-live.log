{"stream": "stderr", "line": "+export function createSyncOrchestrator("}
{"stream": "stderr", "line": "+  options: SyncOrchestratorOptions"}
{"stream": "stderr", "line": "+): SyncOrchestrator {"}
{"stream": "stderr", "line": "+  const broadcast = options.broadcast ?? noopBroadcast;"}
{"stream": "stderr", "line": "+  const now = options.now ?? (() => new Date().toISOString());"}
{"stream": "stderr", "line": "+  const createId = options.createId ?? defaultCreateId;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  async function handleAcceptedDetected("}
{"stream": "stderr", "line": "+    payload: AcceptedDetectedMessage[\"payload\"],"}
{"stream": "stderr", "line": "+    target?: SyncBroadcastTarget"}
{"stream": "stderr", "line": "+  ): Promise<AcceptedSyncOutcome> {"}
{"stream": "stderr", "line": "+    const settings = await options.storage.getSettings();"}
{"stream": "stderr", "line": "+    const initialTimestamp = now();"}
{"stream": "stderr", "line": "+    await options.storage.pruneRetryPayloads(initialTimestamp);"}
{"stream": "stderr", "line": "+    await options.storage.pruneInFlightLocks(initialTimestamp);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!hasRequiredSetup(settings)) {"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"setup_required\","}
{"stream": "stderr", "line": "+        titleSlug: payload.titleSlug,"}
{"stream": "stderr", "line": "+        error: explicitError(\"setup_required\", \"GitHub connection required.\"),"}
{"stream": "stderr", "line": "+        timestamp: initialTimestamp"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!settings.autoSyncEnabled) {"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"auto_sync_disabled\","}
{"stream": "stderr", "line": "+        titleSlug: payload.titleSlug,"}
{"stream": "stderr", "line": "+        repository: settings.selectedRepository,"}
{"stream": "stderr", "line": "+        branchName: settings.selectedBranch.name,"}
{"stream": "stderr", "line": "+        error: explicitError(\"auto_sync_disabled\", \"Auto Sync is off.\"),"}
{"stream": "stderr", "line": "+        timestamp: initialTimestamp"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    let problem: ProblemMetadata;"}
{"stream": "stderr", "line": "+    let accepted: LatestAcceptedSubmissionResult;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    try {"}
{"stream": "stderr", "line": "+      [problem, accepted] = await Promise.all(["}
{"stream": "stderr", "line": "+        options.leetcode.fetchProblemMetadata(payload.titleSlug),"}
{"stream": "stderr", "line": "+        options.leetcode.fetchLatestAcceptedSubmission(payload.titleSlug)"}
{"stream": "stderr", "line": "+      ]);"}
{"stream": "stderr", "line": "+    } catch (error) {"}
{"stream": "stderr", "line": "+      const normalized = normalizeLeetCodeError(error);"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"failed\","}
{"stream": "stderr", "line": "+        titleSlug: payload.titleSlug,"}
{"stream": "stderr", "line": "+        repository: settings.selectedRepository,"}
{"stream": "stderr", "line": "+        branchName: settings.selectedBranch.name,"}
{"stream": "stderr", "line": "+        error: normalized,"}
{"stream": "stderr", "line": "+        timestamp: now()"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!accepted.syncable) {"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"unsupported_language\","}
{"stream": "stderr", "line": "+        titleSlug: problem.titleSlug,"}
{"stream": "stderr", "line": "+        problemTitle: problem.title,"}
{"stream": "stderr", "line": "+        problemFrontendId: problem.frontendId,"}
{"stream": "stderr", "line": "+        language: accepted.submission.language,"}
{"stream": "stderr", "line": "+        repository: settings.selectedRepository,"}
{"stream": "stderr", "line": "+        branchName: settings.selectedBranch.name,"}
{"stream": "stderr", "line": "+        error: explicitError("}
{"stream": "stderr", "line": "+          \"unsupported_language\","}
{"stream": "stderr", "line": "+          `Unsupported LeetCode language: ${accepted.submission.language}`"}
{"stream": "stderr", "line": "+        ),"}
{"stream": "stderr", "line": "+        timestamp: now()"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const prepared = prepareCommit("}
{"stream": "stderr", "line": "+      problem,"}
{"stream": "stderr", "line": "+      accepted.submission,"}
{"stream": "stderr", "line": "+      accepted.identity,"}
{"stream": "stderr", "line": "+      settings.selectedRepository,"}
{"stream": "stderr", "line": "+      settings.selectedBranch"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (await options.storage.isProcessed(prepared.identity)) {"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        kind: \"duplicate_processed\","}
{"stream": "stderr", "line": "+        identity: prepared.identity"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const locked = await options.storage.acquireInFlightLock("}
{"stream": "stderr", "line": "+      prepared.identity,"}
{"stream": "stderr", "line": "+      now()"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!locked) {"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        kind: \"duplicate_in_flight\","}
{"stream": "stderr", "line": "+        identity: prepared.identity"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    try {"}
{"stream": "stderr", "line": "+      if (await options.storage.isProcessed(prepared.identity)) {"}
{"stream": "stderr", "line": "+        return {"}
{"stream": "stderr", "line": "+          kind: \"duplicate_processed\","}
{"stream": "stderr", "line": "+          identity: prepared.identity"}
{"stream": "stderr", "line": "+        };"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      await broadcastStatus("}
{"stream": "stderr", "line": "+        makeRecord({"}
{"stream": "stderr", "line": "+          status: \"syncing\","}
{"stream": "stderr", "line": "+          titleSlug: prepared.problem.titleSlug,"}
{"stream": "stderr", "line": "+          problemTitle: prepared.problem.title,"}
{"stream": "stderr", "line": "+          problemFrontendId: prepared.problem.frontendId,"}
{"stream": "stderr", "line": "+          language: prepared.submission.language,"}
{"stream": "stderr", "line": "+          supportedLanguage: prepared.identity.language,"}
{"stream": "stderr", "line": "+          identity: prepared.identity,"}
{"stream": "stderr", "line": "+          repository: prepared.repository,"}
{"stream": "stderr", "line": "+          branchName: prepared.branch.name,"}
{"stream": "stderr", "line": "+          solutionPath: prepared.solutionPath,"}
{"stream": "stderr", "line": "+          timestamp: now()"}
{"stream": "stderr", "line": "+        }),"}
{"stream": "stderr", "line": "+        null,"}
{"stream": "stderr", "line": "+        target"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      const github = options.githubClientFactory(settings.githubPat);"}
{"stream": "stderr", "line": "+      const result = await commitPrepared(github, prepared, now());"}
{"stream": "stderr", "line": "+      const syncedAt = now();"}
{"stream": "stderr", "line": "+      await options.storage.markProcessed("}
{"stream": "stderr", "line": "+        prepared.identity,"}
{"stream": "stderr", "line": "+        {"}
{"stream": "stderr", "line": "+          commitSha: result.commitSha,"}
{"stream": "stderr", "line": "+          solutionPath: prepared.solutionPath"}
{"stream": "stderr", "line": "+        },"}
{"stream": "stderr", "line": "+        syncedAt"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"synced\","}
{"stream": "stderr", "line": "+        titleSlug: prepared.problem.titleSlug,"}
{"stream": "stderr", "line": "+        problemTitle: prepared.problem.title,"}
{"stream": "stderr", "line": "+        problemFrontendId: prepared.problem.frontendId,"}
{"stream": "stderr", "line": "+        language: prepared.submission.language,"}
{"stream": "stderr", "line": "+        supportedLanguage: prepared.identity.language,"}
{"stream": "stderr", "line": "+        identity: prepared.identity,"}
{"stream": "stderr", "line": "+        repository: result.repository,"}
{"stream": "stderr", "line": "+        branchName: result.branch.name,"}
{"stream": "stderr", "line": "+        solutionPath: prepared.solutionPath,"}
{"stream": "stderr", "line": "+        commitSha: result.commitSha,"}
{"stream": "stderr", "line": "+        commitUrl: result.commitUrl,"}
{"stream": "stderr", "line": "+        fileUrl: result.fileUrls[prepared.solutionPath] ?? null,"}
{"stream": "stderr", "line": "+        timestamp: syncedAt"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    } catch (error) {"}
{"stream": "stderr", "line": "+      const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+      const retryPayload = makeRetryPayload(prepared, normalized, now());"}
{"stream": "stderr", "line": "+      await options.storage.saveRetryPayload(retryPayload, retryPayload.createdAt);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"failed\","}
{"stream": "stderr", "line": "+        titleSlug: prepared.problem.titleSlug,"}
{"stream": "stderr", "line": "+        problemTitle: prepared.problem.title,"}
{"stream": "stderr", "line": "+        problemFrontendId: prepared.problem.frontendId,"}
{"stream": "stderr", "line": "+        language: prepared.submission.language,"}
{"stream": "stderr", "line": "+        supportedLanguage: prepared.identity.language,"}
{"stream": "stderr", "line": "+        identity: prepared.identity,"}
{"stream": "stderr", "line": "+        repository: prepared.repository,"}
{"stream": "stderr", "line": "+        branchName: prepared.branch.name,"}
{"stream": "stderr", "line": "+        solutionPath: prepared.solutionPath,"}
{"stream": "stderr", "line": "+        error: normalized,"}
{"stream": "stderr", "line": "+        retryPayloadId: retryPayload.id,"}
{"stream": "stderr", "line": "+        timestamp: retryPayload.createdAt"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return recordAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+    } finally {"}
