{"stream": "stderr", "line": "+async function handleToastAction("}
{"stream": "stderr", "line": "+  payload: Extract<RuntimeMessage, { type: \"content:toast_action\" }>[\"payload\"],"}
{"stream": "stderr", "line": "+  storage: ExtensionStorage"}
{"stream": "stderr", "line": "+): Promise<null> {"}
{"stream": "stderr", "line": "+  if (payload.action === \"open_options\") {"}
{"stream": "stderr", "line": "+    await chrome.runtime.openOptionsPage();"}
{"stream": "stderr", "line": "+    return null;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (payload.action !== \"open_commit\" && payload.action !== \"open_file\") {"}
{"stream": "stderr", "line": "+    return null;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (payload.recordId === null) {"}
{"stream": "stderr", "line": "+    return null;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const record = (await storage.listHistory()).find((item) => item.id === payload.recordId);"}
{"stream": "stderr", "line": "+  const url = payload.action === \"open_commit\" ? record?.commitUrl : record?.fileUrl;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (url !== undefined && url !== null) {"}
{"stream": "stderr", "line": "+    await chrome.tabs.create({ url });"}
