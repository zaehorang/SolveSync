{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  async function handleRetry("}
{"stream": "stderr", "line": "+    retryPayloadId: string,"}
{"stream": "stderr", "line": "+    target?: SyncBroadcastTarget"}
{"stream": "stderr", "line": "+  ): Promise<RetrySyncOutcome> {"}
{"stream": "stderr", "line": "+    const timestamp = now();"}
{"stream": "stderr", "line": "+    await options.storage.pruneRetryPayloads(timestamp);"}
{"stream": "stderr", "line": "+    await options.storage.pruneInFlightLocks(timestamp);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const payload = await options.storage.getRetryPayload(retryPayloadId);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (payload === null) {"}
{"stream": "stderr", "line": "+      const record = makeRecord({"}
{"stream": "stderr", "line": "+        status: \"failed\","}
{"stream": "stderr", "line": "+        titleSlug: \"\","}
{"stream": "stderr", "line": "+        error: explicitError(\"github_commit_failed\", \"Retry payload is missing or expired.\"),"}
{"stream": "stderr", "line": "+        timestamp"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+      const history = await appendAndBroadcast(record, target);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        kind: \"missing_retry_payload\","}
{"stream": "stderr", "line": "+        record,"}
{"stream": "stderr", "line": "+        history"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (await options.storage.isProcessed(payload.identity)) {"}
{"stream": "stderr", "line": "+      await options.storage.removeRetryPayload(payload.id);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        kind: \"duplicate_processed\","}
{"stream": "stderr", "line": "+        identity: payload.identity"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const locked = await options.storage.acquireInFlightLock(payload.identity, now());"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!locked) {"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        kind: \"duplicate_in_flight\","}
{"stream": "stderr", "line": "+        identity: payload.identity"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    try {"}
{"stream": "stderr", "line": "+      const settings = await options.storage.getSettings();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (settings.githubPat === null || settings.githubPat.trim().length === 0) {"}
{"stream": "stderr", "line": "+        throw explicitError(\"github_auth_failed\", \"GitHub PAT is required.\");"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      await broadcastStatus("}
{"stream": "stderr", "line": "+        makeRecord({"}
{"stream": "stderr", "line": "+          status: \"retrying\","}
{"stream": "stderr", "line": "+          titleSlug: payload.problem.titleSlug,"}
{"stream": "stderr", "line": "+          problemTitle: payload.problem.title,"}
{"stream": "stderr", "line": "+          problemFrontendId: payload.problem.frontendId,"}
{"stream": "stderr", "line": "+          language: payload.submission.language,"}
{"stream": "stderr", "line": "+          supportedLanguage: payload.identity.language,"}
{"stream": "stderr", "line": "+          identity: payload.identity,"}
{"stream": "stderr", "line": "+          repository: payload.repository,"}
{"stream": "stderr", "line": "+          branchName: payload.branch.name,"}
{"stream": "stderr", "line": "+          solutionPath: payload.solutionPath,"}
{"stream": "stderr", "line": "+          retryPayloadId: payload.id,"}
{"stream": "stderr", "line": "+          timestamp: now()"}
{"stream": "stderr", "line": "+        }),"}
{"stream": "stderr", "line": "+        null,"}
{"stream": "stderr", "line": "+        target"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      const github = options.githubClientFactory(settings.githubPat);"}
{"stream": "stderr", "line": "+      const result = await commitPrepared(github, payloadToPrepared(payload), now());"}
{"stream": "stderr", "line": "+      const syncedAt = now();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      await options.storage.markProcessed("}
{"stream": "stderr", "line": "+        payload.identity,"}
{"stream": "stderr", "line": "+        {"}
{"stream": "stderr", "line": "+          commitSha: result.commitSha,"}
{"stream": "stderr", "line": "+          solutionPath: payload.solutionPath"}
{"stream": "stderr", "line": "+        },"}
