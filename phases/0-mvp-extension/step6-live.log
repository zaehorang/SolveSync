{"stream": "stderr", "line": "+function createMemoryStorageArea(seed: Record<string, unknown> = {}): StorageAreaAdapter {"}
{"stream": "stderr", "line": "+  let data = cloneRecord(seed);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    async get(keys?: string | string[] | Record<string, unknown> | null) {"}
{"stream": "stderr", "line": "+      if (keys === null || keys === undefined) {"}
{"stream": "stderr", "line": "+        return cloneRecord(data);"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (typeof keys === \"string\") {"}
{"stream": "stderr", "line": "+        return { [keys]: cloneValue(data[keys]) };"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (Array.isArray(keys)) {"}
{"stream": "stderr", "line": "+        return Object.fromEntries(keys.map((key) => [key, cloneValue(data[key])]));"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        ...cloneRecord(keys),"}
{"stream": "stderr", "line": "+        ...Object.fromEntries("}
{"stream": "stderr", "line": "+          Object.keys(keys)"}
{"stream": "stderr", "line": "+            .filter((key) => key in data)"}
{"stream": "stderr", "line": "+            .map((key) => [key, cloneValue(data[key])])"}
{"stream": "stderr", "line": "+        )"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    },"}
{"stream": "stderr", "line": "+    async set(items: Record<string, unknown>) {"}
{"stream": "stderr", "line": "+      data = {"}
{"stream": "stderr", "line": "+        ...data,"}
{"stream": "stderr", "line": "+        ...cloneRecord(items)"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    },"}
{"stream": "stderr", "line": "+    async remove(keys: string | string[]) {"}
{"stream": "stderr", "line": "+      const keysToRemove = Array.isArray(keys) ? keys : [keys];"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      for (const key of keysToRemove) {"}
{"stream": "stderr", "line": "+        delete data[key];"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
