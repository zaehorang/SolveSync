{"stream": "stderr", "line": "+      return true;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (hasForbiddenMessageSecretKeyInternal(nestedValue, seen)) {"}
