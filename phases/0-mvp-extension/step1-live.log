{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function hasForbiddenMessageSecretKeyInternal("}
{"stream": "stderr", "line": "+  value: unknown,"}
{"stream": "stderr", "line": "+  seen: WeakSet<object>"}
{"stream": "stderr", "line": "+): boolean {"}
{"stream": "stderr", "line": "+  if (value === null || typeof value !== \"object\") {"}
{"stream": "stderr", "line": "+    return false;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (seen.has(value)) {"}
