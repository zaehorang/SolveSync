{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  seen.add(value);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (Array.isArray(value)) {"}
