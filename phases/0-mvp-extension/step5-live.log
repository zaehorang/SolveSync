{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function parseProblemMetadata("}
{"stream": "stderr", "line": "+  data: ProblemMetadataGraphQLData,"}
{"stream": "stderr", "line": "+  requestedTitleSlug: string"}
{"stream": "stderr", "line": "+): ProblemMetadata {"}
{"stream": "stderr", "line": "+  const question = data.question;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!isRecord(question)) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      `LeetCode problem metadata is missing for ${requestedTitleSlug}.`"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const titleSlug = readRequiredString(question, \"titleSlug\");"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    problemId: readRequiredString(question, \"questionId\"),"}
{"stream": "stderr", "line": "+    frontendId: readRequiredString(question, \"questionFrontendId\"),"}
{"stream": "stderr", "line": "+    title: readRequiredString(question, \"title\"),"}
{"stream": "stderr", "line": "+    titleSlug,"}
{"stream": "stderr", "line": "+    difficulty: readRequiredString(question, \"difficulty\") as LeetCodeDifficulty,"}
{"stream": "stderr", "line": "+    url: buildProblemUrl(titleSlug)"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function parseLatestAcceptedListItem("}
{"stream": "stderr", "line": "+  data: SubmissionListGraphQLData,"}
{"stream": "stderr", "line": "+  requestedTitleSlug: string"}
{"stream": "stderr", "line": "+): ParsedSubmissionListItem {"}
{"stream": "stderr", "line": "+  const listContainer = data.questionSubmissionList ?? data.submissionList;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!isRecord(listContainer) || !Array.isArray(listContainer.submissions)) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      \"LeetCode accepted submission list is malformed.\""}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  for (const item of listContainer.submissions) {"}
{"stream": "stderr", "line": "+    if (!isRecord(item) || item.isPending === true) {"}
{"stream": "stderr", "line": "+      continue;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if ("}
{"stream": "stderr", "line": "+      typeof item.statusDisplay === \"string\" &&"}
{"stream": "stderr", "line": "+      item.statusDisplay.trim().toLowerCase() !== \"accepted\""}
{"stream": "stderr", "line": "+    ) {"}
{"stream": "stderr", "line": "+      continue;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const submissionId = readRequiredString(item, \"id\");"}
{"stream": "stderr", "line": "+    const language = readLanguage(item);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    return {"}
{"stream": "stderr", "line": "+      submissionId,"}
{"stream": "stderr", "line": "+      titleSlug:"}
{"stream": "stderr", "line": "+        typeof item.titleSlug === \"string\" && item.titleSlug.trim().length > 0"}
{"stream": "stderr", "line": "+          ? item.titleSlug"}
{"stream": "stderr", "line": "+          : requestedTitleSlug,"}
{"stream": "stderr", "line": "+      language,"}
{"stream": "stderr", "line": "+      timestamp: item.timestamp"}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  throw explicitNormalizedError("}
{"stream": "stderr", "line": "+    \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+    `No latest accepted submission found for ${requestedTitleSlug}.`"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function parseSubmissionDetails("}
{"stream": "stderr", "line": "+  data: SubmissionDetailsGraphQLData"}
{"stream": "stderr", "line": "+): ParsedSubmissionDetails {"}
{"stream": "stderr", "line": "+  const details = data.submissionDetails;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!isRecord(details)) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      \"LeetCode submission details are missing.\""}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const code = readRequiredString(details, \"code\");"}
{"stream": "stderr", "line": "+  if (code.trim().length === 0) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      \"LeetCode accepted submission code is missing.\""}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const question = details.question;"}
{"stream": "stderr", "line": "+  const titleSlug ="}
{"stream": "stderr", "line": "+    isRecord(question) && typeof question.titleSlug === \"string\""}
{"stream": "stderr", "line": "+      ? question.titleSlug"}
{"stream": "stderr", "line": "+      : null;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    titleSlug,"}
{"stream": "stderr", "line": "+    language: readOptionalLanguage(details),"}
{"stream": "stderr", "line": "+    code,"}
{"stream": "stderr", "line": "+    timestamp: details.timestamp"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function readLanguage(record: Record<string, unknown>): LeetCodeLanguage {"}
{"stream": "stderr", "line": "+  const language = readOptionalLanguage(record);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (language === null) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      \"LeetCode submission language is missing.\""}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return language;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function readOptionalLanguage(record: Record<string, unknown>): LeetCodeLanguage | null {"}
{"stream": "stderr", "line": "+  const candidates: unknown[] = [];"}
{"stream": "stderr", "line": "+  const lang = record.lang;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (isRecord(lang)) {"}
{"stream": "stderr", "line": "+    candidates.push(lang.verboseName, lang.name);"}
{"stream": "stderr", "line": "+  } else {"}
{"stream": "stderr", "line": "+    candidates.push(lang);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  candidates.push(record.langName, record.language);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const language = candidates.find("}
{"stream": "stderr", "line": "+    (candidate): candidate is string =>"}
{"stream": "stderr", "line": "+      typeof candidate === \"string\" && candidate.trim().length > 0"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return language === undefined ? null : (language as LeetCodeLanguage);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function readRequiredString(record: Record<string, unknown>, key: string): string {"}
{"stream": "stderr", "line": "+  const value = record[key];"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (typeof value !== \"string\" || value.trim().length === 0) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      `LeetCode response is missing ${key}.`"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return value;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function toGraphQLSubmissionId(value: string): number {"}
{"stream": "stderr", "line": "+  const submissionId = Number.parseInt(value, 10);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!Number.isSafeInteger(submissionId) || submissionId <= 0) {"}
{"stream": "stderr", "line": "+    throw explicitNormalizedError("}
{"stream": "stderr", "line": "+      \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+      `LeetCode submission id is malformed: ${value}`"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return submissionId;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function toIsoDateString(value: unknown): IsoDateString {"}
{"stream": "stderr", "line": "+  let date: Date;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (typeof value === \"number\") {"}
{"stream": "stderr", "line": "+    date = new Date(toTimestampMs(value));"}
{"stream": "stderr", "line": "+  } else if (typeof value === \"string\" && value.trim().length > 0) {"}
{"stream": "stderr", "line": "+    const numericValue = Number(value);"}
