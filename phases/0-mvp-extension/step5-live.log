  return {\n   417\t    titleSlug,\n   418\t    language: readOptionalLanguage(details),\n   419\t    code,\n   420\t    timestamp: details.timestamp\n   421\t  };\n   422\t}\n   423\t\n   424\tfunction readLanguage(record: Record<string, unknown>): LeetCodeLanguage {\n   425\t  const language = readOptionalLanguage(record);\n   426\t\n   427\t  if (language === null) {\n   428\t    throw explicitNormalizedError(\n   429\t      \"leetcode_fetch_failed\",\n   430\t      \"LeetCode submission language is missing.\"\n   431\t    );\n   432\t  }\n   433\t\n   434\t  return language;\n   435\t}\n   436\t\n   437\tfunction readOptionalLanguage(record: Record<string, unknown>): LeetCodeLanguage | null {\n   438\t  const candidates: unknown[] = [];\n   439\t  const lang = record.lang;\n   440\t\n   441\t  if (isRecord(lang)) {\n   442\t    candidates.push(lang.verboseName, lang.name);\n   443\t  } else {\n   444\t    candidates.push(lang);\n   445\t  }\n   446\t\n   447\t  candidates.push(record.langName, record.language);\n   448\t\n   449\t  const language = candidates.find(\n   450\t    (candidate): candidate is string =>\n   451\t      typeof candidate === \"string\" && candidate.trim().length > 0\n   452\t  );\n   453\t\n   454\t  return language === undefined ? null : (language as LeetCodeLanguage);\n   455\t}\n   456\t\n   457\tfunction readRequiredString(record: Record<string, unknown>, key: string): string {\n   458\t  const value = record[key];\n   459\t\n   460\t  if (typeof value !== \"string\" || value.trim().length === 0) {\n   461\t    throw explicitNormalizedError(\n   462\t      \"leetcode_fetch_failed\",\n   463\t      `LeetCode response is missing ${key}.`\n   464\t    );\n   465\t  }\n   466\t\n   467\t  return value;\n   468\t}\n   469\t\n   470\tfunction toGraphQLSubmissionId(value: string): number {\n   471\t  const submissionId = Number.parseInt(value, 10);\n   472\t\n   473\t  if (!Number.isSafeInteger(submissionId) || submissionId <= 0) {\n   474\t