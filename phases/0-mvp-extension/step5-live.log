{"type":"item.completed","item":{"id":"item_41","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/background/client/leetcode.test.ts | sed -n '1,280p'\"","aggregated_output":"     1\timport { describe, expect, it, vi } from \"vitest\";\n     2\t\n     3\timport {\n     4\t  LeetCodeClient,\n     5\t  type LeetCodeFetch,\n     6\t  fetchLatestAcceptedSubmission,\n     7\t  fetchProblemMetadata\n     8\t} from \"./leetcode\";\n     9\t\n    10\tdescribe(\"LeetCode background client\", () => {\n    11\t  it(\"parses problem metadata without requesting problem content\", async () => {\n    12\t    const fetchImpl = mockFetch(\n    13\t      graphQLResponse({\n    14\t        question: {\n    15\t          questionId: \"1\",\n    16\t          questionFrontendId: \"1\",\n    17\t          title: \"Two Sum\",\n    18\t          titleSlug: \"two-sum\",\n    19\t          difficulty: \"Easy\"\n    20\t        }\n    21\t      })\n    22\t    );\n    23\t    const metadata = await fetchProblemMetadata(\"two-sum\", { fetchImpl });\n    24\t\n    25\t    expect(metadata).toEqual({\n    26\t      problemId: \"1\",\n    27\t      frontendId: \"1\",\n    28\t      title: \"Two Sum\",\n    29\t      titleSlug: \"two-sum\",\n    30\t      difficulty: \"Easy\",\n    31\t      url: \"https://leetcode.com/problems/two-sum/\"\n    32\t    });\n    33\t    expect(requestBody(fetchImpl, 0).query).not.toContain(\"content\");\n    34\t    expect(fetchCalls(fetchImpl)[0]?.[1]?.credentials).toBe(\"include\");\n    35\t  });\n    36\t\n    37\t  it(\"parses the latest accepted submission detail and supported language\", async () => {\n    38\t    const fetchImpl = mockFetch(\n    39\t      graphQLResponse({\n    40\t        questionSubmissionList: {\n    41\t          submissions: [\n    42\t            {\n    43\t              id: \"123456789\",\n    44\t              titleSlug: \"two-sum\",\n    45\t              statusDisplay: \"Accepted\",\n    46\t              lang: \"swif