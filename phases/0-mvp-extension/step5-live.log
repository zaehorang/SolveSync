{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch {"}
{"stream": "stderr", "line": "+    return text;"}
{"stream": "stderr", "line": "+  }"}
