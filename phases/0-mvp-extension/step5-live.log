{"stream": "stderr", "line": "+    this.context = {"}
{"stream": "stderr", "line": "+      fetchImpl: options.fetchImpl ?? fetch,"}
{"stream": "stderr", "line": "+      graphqlUrl: options.graphqlUrl ?? LEETCODE_GRAPHQL_URL"}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  async fetchProblemMetadata(titleSlug: string): Promise<ProblemMetadata> {"}
{"stream": "stderr", "line": "+    return this.withNormalizedErrors(async () => {"}
{"stream": "stderr", "line": "+      const data = await this.graphql<ProblemMetadataGraphQLData>("}
{"stream": "stderr", "line": "+        PROBLEM_METADATA_QUERY,"}
{"stream": "stderr", "line": "+        { titleSlug }"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return parseProblemMetadata(data, titleSlug);"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  async fetchLatestAcceptedSubmission("}
{"stream": "stderr", "line": "+    titleSlug: string"}
{"stream": "stderr", "line": "+  ): Promise<LatestAcceptedSubmissionResult> {"}
{"stream": "stderr", "line": "+    return this.withNormalizedErrors(async () => {"}
{"stream": "stderr", "line": "+      const listData = await this.graphql<SubmissionListGraphQLData>("}
{"stream": "stderr", "line": "+        LATEST_ACCEPTED_SUBMISSION_QUERY,"}
{"stream": "stderr", "line": "+        {"}
{"stream": "stderr", "line": "+          titleSlug,"}
{"stream": "stderr", "line": "+          limit: SUBMISSION_LIST_LIMIT,"}
{"stream": "stderr", "line": "+          offset: 0,"}
{"stream": "stderr", "line": "+          status: ACCEPTED_STATUS_CODE"}
{"stream": "stderr", "line": "+        }"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+      const latest = parseLatestAcceptedListItem(listData, titleSlug);"}
{"stream": "stderr", "line": "+      const detailData = await this.graphql<SubmissionDetailsGraphQLData>("}
{"stream": "stderr", "line": "+        SUBMISSION_DETAILS_QUERY,"}
{"stream": "stderr", "line": "+        { submissionId: toGraphQLSubmissionId(latest.submissionId) }"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+      const details = parseSubmissionDetails(detailData);"}
{"stream": "stderr", "line": "+      const language = details.language ?? latest.language;"}
{"stream": "stderr", "line": "+      const submittedAt = toIsoDateString(details.timestamp ?? latest.timestamp);"}
{"stream": "stderr", "line": "+      const submissionTitleSlug = details.titleSlug ?? latest.titleSlug;"}
{"stream": "stderr", "line": "+      const submission: AcceptedSubmission = {"}
{"stream": "stderr", "line": "+        submissionId: latest.submissionId,"}
{"stream": "stderr", "line": "+        titleSlug: submissionTitleSlug,"}
{"stream": "stderr", "line": "+        language,"}
{"stream": "stderr", "line": "+        code: details.code,"}
{"stream": "stderr", "line": "+        acceptedAt: submittedAt"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+      const supportedLanguage = mapLeetCodeLanguage(language);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (supportedLanguage === null) {"}
{"stream": "stderr", "line": "+        return {"}
{"stream": "stderr", "line": "+          submission,"}
{"stream": "stderr", "line": "+          supportedLanguage,"}
{"stream": "stderr", "line": "+          syncable: false,"}
{"stream": "stderr", "line": "+          identity: null"}
{"stream": "stderr", "line": "+        };"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      return {"}
{"stream": "stderr", "line": "+        submission,"}
{"stream": "stderr", "line": "+        supportedLanguage,"}
{"stream": "stderr", "line": "+        syncable: true,"}
{"stream": "stderr", "line": "+        identity: {"}
{"stream": "stderr", "line": "+          submissionId: submission.submissionId,"}
{"stream": "stderr", "line": "+          titleSlug: submission.titleSlug,"}
{"stream": "stderr", "line": "+          language: supportedLanguage"}
{"stream": "stderr", "line": "+        }"}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  private async graphql<T>("}
{"stream": "stderr", "line": "+    query: string,"}
{"stream": "stderr", "line": "+    variables: Record<string, unknown>"}
{"stream": "stderr", "line": "+  ): Promise<T> {"}
{"stream": "stderr", "line": "+    let response: Response;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    try {"}
{"stream": "stderr", "line": "+      response = await this.context.fetchImpl(this.context.graphqlUrl, {"}
{"stream": "stderr", "line": "+        method: \"POST\","}
{"stream": "stderr", "line": "+        credentials: \"include\","}
{"stream": "stderr", "line": "+        headers: {"}
{"stream": "stderr", "line": "+          Accept: \"application/json\","}
{"stream": "stderr", "line": "+          \"Content-Type\": \"application/json\""}
{"stream": "stderr", "line": "+        },"}
{"stream": "stderr", "line": "+        body: JSON.stringify({"}
{"stream": "stderr", "line": "+          query,"}
{"stream": "stderr", "line": "+          variables"}
{"stream": "stderr", "line": "+        })"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+    } catch (error) {"}
{"stream": "stderr", "line": "+      throw normalizeLeetCodeError(error);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const text = await response.text();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw new LeetCodeHttpError("}
{"stream": "stderr", "line": "+        response.status,"}
{"stream": "stderr", "line": "+        parseErrorMessage(text) ?? response.statusText,"}
{"stream": "stderr", "line": "+        inferLeetCodeResponseErrorCode(response)"}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const parsed = parseJson(text);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!isRecord(parsed)) {"}
{"stream": "stderr", "line": "+      throw explicitNormalizedError("}
{"stream": "stderr", "line": "+        \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+        \"LeetCode GraphQL response is not an object.\""}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const graphQLResponse = parsed as GraphQLResponse<T>;"}
{"stream": "stderr", "line": "+    if (Array.isArray(graphQLResponse.errors) && graphQLResponse.errors.length > 0) {"}
{"stream": "stderr", "line": "+      const message = graphQLResponse.errors"}
{"stream": "stderr", "line": "+        .map((error) => error.message)"}
{"stream": "stderr", "line": "+        .filter((message): message is string => typeof message === \"string\")"}
{"stream": "stderr", "line": "+        .join(\"; \");"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      throw explicitNormalizedError("}
{"stream": "stderr", "line": "+        isAuthLikeMessage(message) ? \"leetcode_auth_required\" : \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+        message.length > 0 ? message : \"LeetCode GraphQL returned errors.\""}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (graphQLResponse.data === undefined || graphQLResponse.data === null) {"}
{"stream": "stderr", "line": "+      throw explicitNormalizedError("}
{"stream": "stderr", "line": "+        \"leetcode_fetch_failed\","}
{"stream": "stderr", "line": "+        \"LeetCode GraphQL response is missing data.\""}
{"stream": "stderr", "line": "+      );"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    return graphQLResponse.data;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  private async withNormalizedErrors<T>(operation: () => Promise<T>): Promise<T> {"}
{"stream": "stderr", "line": "+    try {"}
{"stream": "stderr", "line": "+      return await operation();"}
{"stream": "stderr", "line": "+    } catch (error) {"}
{"stream": "stderr", "line": "+      throw normalizeLeetCodeError(error);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+export function createLeetCodeClient("}
{"stream": "stderr", "line": "+  options: LeetCodeClientOptions = {}"}
{"stream": "stderr", "line": "+): LeetCodeClient {"}
{"stream": "stderr", "line": "+  return new LeetCodeClient(options);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+export async function fetchProblemMetadata("}
{"stream": "stderr", "line": "+  titleSlug: string,"}
{"stream": "stderr", "line": "+  options: LeetCodeClientOptions = {}"}
