\t}\n   222\t\n   223\tfunction graphQLResponse(data: unknown, status = 200): Response {\n   224\t  return jsonResponse({ data }, status);\n   225\t}\n   226\t\n   227\tfunction jsonResponse(body: unknown, status = 200): Response {\n   228\t  return new Response(JSON.stringify(body), {\n   229\t    status,\n   230\t    headers: {\n   231\t      \"Content-Type\": \"application/json\"\n   232\t    }\n   233\t  });\n   234\t}\n   235\t\n   236\tfunction requestBody(\n   237\t  fetchImpl: LeetCodeFetch,\n   238\t  callIndex: number\n   239\t): { query: string; variables: Record<string, unknown> } {\n   240\t  const init = fetchCalls(fetchImpl)[callIndex]?.[1];\n   241\t\n   242\t  if (typeof init?.body !== \"string\") {\n   243\t    throw new Error(\"Expected JSON request body.\");\n   244\t  }\n   245\t\n   246\t  return JSON.parse(init.body) as {\n   247\t    query: string;\n   248\t    variables: Record<string, unknown>;\n   249\t  };\n   250\t}\n   251\t\n   252\tfunction fetchCalls(\n   253\t  fetchImpl: LeetCodeFetch\n   254\t): Array<[RequestInfo | URL, RequestInit | undefined]> {\n   255\t  return vi.mocked(fetchImpl).mock.calls as Array<\n   256\t    [RequestInfo | URL, RequestInit | undefined]\n   257\t  >;\n   258\t}\n","exit_code":0,"status":"completed"}}
