{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.githubPatInput = elements.patInput.value;"}
{"stream": "stderr", "line": "+  state.autoSyncEnabled = elements.autoSyncCheckbox.checked;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const validation = validateSettingsDraft({"}
