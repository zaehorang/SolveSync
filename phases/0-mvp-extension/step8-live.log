{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    const settings = await readSettings();"}
{"stream": "stderr", "line": "+    applySettingsToState(state, settings);"}
{"stream": "stderr", "line": "+    state.loadingSettings = false;"}
{"stream": "stderr", "line": "+    state.saveMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (settings.githubPat !== null && settings.selectedRepository !== null) {"}
{"stream": "stderr", "line": "+      void loadBranches(elements, state, settings.selectedRepository);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    state.loadingSettings = false;"}
{"stream": "stderr", "line": "+    state.saveMessage = {"}
{"stream": "stderr", "line": "+      text: normalizeError(error).userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function bindEvents(elements: OptionsElements, state: OptionsRuntimeState): void {"}
{"stream": "stderr", "line": "+  elements.togglePatButton.addEventListener(\"click\", () => {"}
{"stream": "stderr", "line": "+    state.patVisible = !state.patVisible;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.patInput.addEventListener(\"input\", () => {"}
{"stream": "stderr", "line": "+    state.githubPatInput = elements.patInput.value;"}
{"stream": "stderr", "line": "+    state.patMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.repositorySearchInput.addEventListener(\"input\", () => {"}
{"stream": "stderr", "line": "+    state.repositoryQuery = elements.repositorySearchInput.value;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.loadRepositoriesButton.addEventListener(\"click\", () => {"}
{"stream": "stderr", "line": "+    void loadRepositories(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.repositorySelect.addEventListener(\"change\", () => {"}
{"stream": "stderr", "line": "+    const selected = state.repositories.find("}
{"stream": "stderr", "line": "+      (repository) => repository.fullName === elements.repositorySelect.value"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.selectedRepository = selected ?? null;"}
{"stream": "stderr", "line": "+    state.branches = [];"}
{"stream": "stderr", "line": "+    state.selectedBranch = null;"}
{"stream": "stderr", "line": "+    state.branchMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    state.createBranchMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (selected !== undefined) {"}
{"stream": "stderr", "line": "+      void loadBranches(elements, state, selected);"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.branchSelect.addEventListener(\"change\", () => {"}
{"stream": "stderr", "line": "+    const selected = state.branches.find("}
{"stream": "stderr", "line": "+      (branch) => branch.name === elements.branchSelect.value"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.selectedBranch = selected ?? null;"}
{"stream": "stderr", "line": "+    state.branchMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.createBranchInput.addEventListener(\"input\", () => {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.createBranchButton.addEventListener(\"click\", () => {"}
{"stream": "stderr", "line": "+    void createBranch(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.autoSyncCheckbox.addEventListener(\"change\", () => {"}
{"stream": "stderr", "line": "+    state.autoSyncEnabled = elements.autoSyncCheckbox.checked;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.testConnectionButton.addEventListener(\"click\", () => {"}
{"stream": "stderr", "line": "+    void testConnection(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.form.addEventListener(\"submit\", (event) => {"}
{"stream": "stderr", "line": "+    event.preventDefault();"}
{"stream": "stderr", "line": "+    void saveSettingsFromForm(elements, state);"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function loadRepositories("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.githubPatInput = elements.patInput.value;"}
{"stream": "stderr", "line": "+  state.repositoryQuery = elements.repositorySearchInput.value;"}
{"stream": "stderr", "line": "+  state.patMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+  state.repositoryMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+  state.saveMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.githubPatInput.trim().length === 0) {"}
{"stream": "stderr", "line": "+    state.patMessage = {"}
{"stream": "stderr", "line": "+      text: \"GitHub PAT is required before loading repositories.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  state.loadingRepositories = true;"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput)"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<RepositoryListResult>({"}
{"stream": "stderr", "line": "+      type: \"github:repositories:list\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        query: null,"}
{"stream": "stderr", "line": "+        page: 1,"}
{"stream": "stderr", "line": "+        perPage: 100"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.repositories = mergeRepositories("}
{"stream": "stderr", "line": "+      response.data.repositories,"}
{"stream": "stderr", "line": "+      state.selectedRepository === null ? [] : [state.selectedRepository]"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if ("}
{"stream": "stderr", "line": "+      state.selectedRepository !== null &&"}
{"stream": "stderr", "line": "+      !state.repositories.some("}
{"stream": "stderr", "line": "+        (repository) => repository.fullName === state.selectedRepository?.fullName"}
{"stream": "stderr", "line": "+      )"}
{"stream": "stderr", "line": "+    ) {"}
{"stream": "stderr", "line": "+      state.selectedRepository = null;"}
{"stream": "stderr", "line": "+      state.branches = [];"}
{"stream": "stderr", "line": "+      state.selectedBranch = null;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (response.data.totalCount === 0) {"}
{"stream": "stderr", "line": "+      state.connectionStatus = createConnectionStatus(\"no_accessible_repositories\");"}
{"stream": "stderr", "line": "+      state.repositoryMessage = {"}
{"stream": "stderr", "line": "+        text: \"No accessible repositories. Check the token selected repository permission.\","}
{"stream": "stderr", "line": "+        tone: \"warning\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+      await saveSettings({"}
{"stream": "stderr", "line": "+        connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+      });"}
{"stream": "stderr", "line": "+    } else if (response.data.hasMore) {"}
{"stream": "stderr", "line": "+      state.repositoryMessage = {"}
{"stream": "stderr", "line": "+        text: `Loaded ${response.data.repositories.length} of ${response.data.totalCount} repositories. Use search to narrow the list.`,"}
{"stream": "stderr", "line": "+        tone: \"neutral\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    } else {"}
{"stream": "stderr", "line": "+      state.repositoryMessage = {"}
{"stream": "stderr", "line": "+        text: `Loaded ${response.data.repositories.length} repositories.`,"}
{"stream": "stderr", "line": "+        tone: \"success\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.repositoryMessage = {"}
{"stream": "stderr", "line": "+      text: normalized.userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.loadingRepositories = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function loadBranches("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState,"}
{"stream": "stderr", "line": "+  repository: RepositoryRef"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.loadingBranches = true;"}
{"stream": "stderr", "line": "+  state.branchMessage = {"}
{"stream": "stderr", "line": "+    text: \"Loading branches...\","}
{"stream": "stderr", "line": "+    tone: \"neutral\""}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<BranchRef[]>({"}
{"stream": "stderr", "line": "+      type: \"github:branches:list\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        repository"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.branches = response.data;"}
{"stream": "stderr", "line": "+    const branchName = getDefaultBranchSelection("}
{"stream": "stderr", "line": "+      repository,"}
{"stream": "stderr", "line": "+      state.branches,"}
{"stream": "stderr", "line": "+      state.selectedBranch?.name ?? null"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.selectedBranch ="}
{"stream": "stderr", "line": "+      branchName === null"}
{"stream": "stderr", "line": "+        ? null"}
{"stream": "stderr", "line": "+        : state.branches.find((branch) => branch.name === branchName) ?? null;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (state.branches.length === 0) {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: \"No branches found. Empty repositories cannot create a branch from default branch HEAD.\","}
{"stream": "stderr", "line": "+        tone: \"warning\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    } else if (state.selectedBranch?.name === repository.defaultBranch) {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: `Default branch selected: ${repository.defaultBranch}.`,"}
{"stream": "stderr", "line": "+        tone: \"success\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    } else {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: `Loaded ${state.branches.length} branches.`,"}
{"stream": "stderr", "line": "+        tone: \"success\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.branchMessage = {"}
{"stream": "stderr", "line": "+      text: normalized.userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.loadingBranches = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function createBranch("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  const branchName = elements.createBranchInput.value.trim();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.selectedRepository === null) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Choose a repository before creating a branch.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (branchName.length === 0) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Enter a branch name.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.branches.some((branch) => branch.name === branchName)) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Branch already exists. Select it from the branch picker.\","}
{"stream": "stderr", "line": "+      tone: \"warning\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  state.creatingBranch = true;"}
{"stream": "stderr", "line": "+  state.createBranchMessage = {"}
{"stream": "stderr", "line": "+    text: \"Creating branch...\","}
{"stream": "stderr", "line": "+    tone: \"neutral\""}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput)"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<BranchRef>({"}
{"stream": "stderr", "line": "+      type: \"github:branch:create\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        repository: state.selectedRepository,"}
{"stream": "stderr", "line": "+        branchName"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.branches = mergeBranches(state.branches, [response.data]);"}
{"stream": "stderr", "line": "+    state.selectedBranch = response.data;"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus(\"branch_created\");"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: `Created branch ${response.data.name}.`,"}
{"stream": "stderr", "line": "+      tone: \"success\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    elements.createBranchInput.value = \"\";"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput),"}
{"stream": "stderr", "line": "+      selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+      selectedBranch: state.selectedBranch,"}
{"stream": "stderr", "line": "+      autoSyncEnabled: state.autoSyncEnabled,"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: normalized.userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.creatingBranch = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function testConnection("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.githubPatInput = elements.patInput.value;"}
{"stream": "stderr", "line": "+  state.autoSyncEnabled = elements.autoSyncCheckbox.checked;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const validation = validateSettingsDraft({"}
{"stream": "stderr", "line": "+    githubPat: state.githubPatInput,"}
{"stream": "stderr", "line": "+    selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+    selectedBranch: state.selectedBranch"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+  applyValidationMessages(state, validation);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!validation.isValid) {"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  state.testingConnection = true;"}
{"stream": "stderr", "line": "+  state.connectionStatus = createConnectionStatus(\"testing\");"}
{"stream": "stderr", "line": "+  state.saveMessage = EMPTY_MESSAGE;"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput),"}
{"stream": "stderr", "line": "+      selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+      selectedBranch: state.selectedBranch,"}
{"stream": "stderr", "line": "+      autoSyncEnabled: state.autoSyncEnabled,"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<ConnectionTestResult>({"}
{"stream": "stderr", "line": "+      type: \"github:connection:test\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        repository: state.selectedRepository as RepositoryRef,"}
{"stream": "stderr", "line": "+        branchName: (state.selectedBranch as BranchRef).name"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.selectedRepository = response.data.repository;"}
{"stream": "stderr", "line": "+    state.selectedBranch = response.data.branch;"}
{"stream": "stderr", "line": "+    state.repositories = mergeRepositories(state.repositories, [response.data.repository]);"}
{"stream": "stderr", "line": "+    state.branches = mergeBranches(state.branches, [response.data.branch]);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus(\"connected\");"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput),"}
{"stream": "stderr", "line": "+      selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+      selectedBranch: state.selectedBranch,"}
{"stream": "stderr", "line": "+      autoSyncEnabled: state.autoSyncEnabled,"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.testingConnection = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function saveSettingsFromForm("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.githubPatInput = elements.patInput.value;"}
{"stream": "stderr", "line": "+  state.autoSyncEnabled = elements.autoSyncCheckbox.checked;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  const validation = validateSettingsDraft({"}
{"stream": "stderr", "line": "+    githubPat: state.githubPatInput,"}
{"stream": "stderr", "line": "+    selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+    selectedBranch: state.selectedBranch"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+  applyValidationMessages(state, validation);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!validation.isValid) {"}
{"stream": "stderr", "line": "+    state.saveMessage = {"}
{"stream": "stderr", "line": "+      text: \"Complete the required settings before saving.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  state.savingSettings = true;"}
{"stream": "stderr", "line": "+  state.saveMessage = {"}
{"stream": "stderr", "line": "+    text: \"Saving settings...\","}
{"stream": "stderr", "line": "+    tone: \"neutral\""}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput),"}
{"stream": "stderr", "line": "+      selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+      selectedBranch: state.selectedBranch,"}
{"stream": "stderr", "line": "+      autoSyncEnabled: state.autoSyncEnabled,"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+    state.saveMessage = {"}
{"stream": "stderr", "line": "+      text: \"Settings saved.\","}
{"stream": "stderr", "line": "+      tone: \"success\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    state.saveMessage = {"}
{"stream": "stderr", "line": "+      text: normalizeError(error).userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.savingSettings = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function applySettingsToState("}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState,"}
{"stream": "stderr", "line": "+  settings: SettingsState"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  state.githubPatInput = settings.githubPat ?? \"\";"}
{"stream": "stderr", "line": "+  state.selectedRepository = settings.selectedRepository;"}
{"stream": "stderr", "line": "+  state.selectedBranch = settings.selectedBranch;"}
{"stream": "stderr", "line": "+  state.repositories ="}
{"stream": "stderr", "line": "+    settings.selectedRepository === null ? [] : [settings.selectedRepository];"}
{"stream": "stderr", "line": "+  state.branches = settings.selectedBranch === null ? [] : [settings.selectedBranch];"}
{"stream": "stderr", "line": "+  state.autoSyncEnabled = settings.autoSyncEnabled;"}
{"stream": "stderr", "line": "+  state.connectionStatus = settings.connectionStatus;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function applyValidationMessages("}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState,"}
{"stream": "stderr", "line": "+  validation: SettingsValidationResult"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  state.patMessage ="}
{"stream": "stderr", "line": "+    validation.errors.githubPat === undefined"}
{"stream": "stderr", "line": "+      ? EMPTY_MESSAGE"}
{"stream": "stderr", "line": "+      : {"}
{"stream": "stderr", "line": "+          text: validation.errors.githubPat,"}
{"stream": "stderr", "line": "+          tone: \"error\""}
{"stream": "stderr", "line": "+        };"}
{"stream": "stderr", "line": "+  state.repositoryMessage ="}
{"stream": "stderr", "line": "+    validation.errors.repository === undefined"}
{"stream": "stderr", "line": "+      ? state.repositoryMessage"}
{"stream": "stderr", "line": "+      : {"}
{"stream": "stderr", "line": "+          text: validation.errors.repository,"}
{"stream": "stderr", "line": "+          tone: \"error\""}
{"stream": "stderr", "line": "+        };"}
{"stream": "stderr", "line": "+  state.branchMessage ="}
{"stream": "stderr", "line": "+    validation.errors.branch === undefined"}
{"stream": "stderr", "line": "+      ? state.branchMessage"}
{"stream": "stderr", "line": "+      : {"}
{"stream": "stderr", "line": "+          text: validation.errors.branch,"}
{"stream": "stderr", "line": "+          tone: \"error\""}
{"stream": "stderr", "line": "+        };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function render(elements: OptionsElements, state: OptionsRuntimeState): void {"}
{"stream": "stderr", "line": "+  elements.status.textContent = state.loadingSettings"}
{"stream": "stderr", "line": "+    ? \"Loading settings...\""}
{"stream": "stderr", "line": "+    : \"Settings are stored in this browser profile.\";"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.patInput.type = state.patVisible ? \"text\" : \"password\";"}
{"stream": "stderr", "line": "+  elements.patInput.value = state.githubPatInput;"}
{"stream": "stderr", "line": "+  elements.togglePatButton.textContent = state.patVisible ? \"Hide\" : \"Show\";"}
{"stream": "stderr", "line": "+  renderInlineMessage(elements.patError, state.patMessage);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.repositorySearchInput.value = state.repositoryQuery;"}
{"stream": "stderr", "line": "+  elements.loadRepositoriesButton.disabled = state.loadingRepositories;"}
{"stream": "stderr", "line": "+  elements.loadRepositoriesButton.textContent = state.loadingRepositories"}
{"stream": "stderr", "line": "+    ? \"Loading...\""}
{"stream": "stderr", "line": "+    : \"Load repositories\";"}
{"stream": "stderr", "line": "+  renderRepositorySelect(elements, state);"}
{"stream": "stderr", "line": "+  renderInlineMessage(elements.repositoryStatus, state.repositoryMessage);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  renderBranchSelect(elements, state);"}
{"stream": "stderr", "line": "+  renderInlineMessage(elements.branchStatus, state.branchMessage);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  renderCreateBranchControls(elements, state);"}
{"stream": "stderr", "line": "+  renderInlineMessage(elements.createBranchStatus, state.createBranchMessage);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.autoSyncCheckbox.checked = state.autoSyncEnabled;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.testConnectionButton.disabled ="}
{"stream": "stderr", "line": "+    state.testingConnection || state.selectedRepository === null || state.selectedBranch === null;"}
{"stream": "stderr", "line": "+  elements.testConnectionButton.textContent = state.testingConnection"}
{"stream": "stderr", "line": "+    ? \"Testing...\""}
{"stream": "stderr", "line": "+    : \"Test connection\";"}
{"stream": "stderr", "line": "+  renderConnectionStatus(elements.connectionStatusBox, state.connectionStatus);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.saveButton.disabled = state.savingSettings;"}
{"stream": "stderr", "line": "+  elements.saveButton.textContent = state.savingSettings ? \"Saving...\" : \"Save settings\";"}
{"stream": "stderr", "line": "+  renderInlineMessage(elements.saveStatus, state.saveMessage);"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function renderRepositorySelect("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  const filterState = getRepositoryFilterState("}
{"stream": "stderr", "line": "+    state.repositories,"}
{"stream": "stderr", "line": "+    state.repositoryQuery"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.repositorySelect.replaceChildren("}
{"stream": "stderr", "line": "+    ...filterState.visibleRepositories.map((repository) => {"}
{"stream": "stderr", "line": "+      const option = document.createElement(\"option\");"}
{"stream": "stderr", "line": "+      option.value = repository.fullName;"}
{"stream": "stderr", "line": "+      option.textContent = `${repository.fullName}${repository.private ? \" (private)\" : \"\"}`;"}
{"stream": "stderr", "line": "+      return option;"}
{"stream": "stderr", "line": "+    })"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.selectedRepository === null) {"}
{"stream": "stderr", "line": "+    elements.repositorySelect.selectedIndex = -1;"}
{"stream": "stderr", "line": "+  } else {"}
{"stream": "stderr", "line": "+    elements.repositorySelect.value = state.selectedRepository.fullName;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (elements.repositorySelect.value !== state.selectedRepository.fullName) {"}
{"stream": "stderr", "line": "+      elements.repositorySelect.selectedIndex = -1;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if ("}
{"stream": "stderr", "line": "+    state.repositories.length > 0 &&"}
{"stream": "stderr", "line": "+    !filterState.hasMatches &&"}
{"stream": "stderr", "line": "+    state.repositoryMessage.tone !== \"error\""}
{"stream": "stderr", "line": "+  ) {"}
{"stream": "stderr", "line": "+    state.repositoryMessage = {"}
{"stream": "stderr", "line": "+      text: \"No repositories match the search.\","}
{"stream": "stderr", "line": "+      tone: \"warning\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function renderBranchSelect("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  elements.branchSelect.disabled ="}
{"stream": "stderr", "line": "+    state.selectedRepository === null || state.loadingBranches || state.branches.length === 0;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.branchSelect.replaceChildren("}
{"stream": "stderr", "line": "+    ...state.branches.map((branch) => {"}
{"stream": "stderr", "line": "+      const option = document.createElement(\"option\");"}
{"stream": "stderr", "line": "+      option.value = branch.name;"}
{"stream": "stderr", "line": "+      option.textContent = branch.protected ? `${branch.name} (protected)` : branch.name;"}
{"stream": "stderr", "line": "+      return option;"}
{"stream": "stderr", "line": "+    })"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.selectedBranch === null) {"}
{"stream": "stderr", "line": "+    elements.branchSelect.selectedIndex = -1;"}
{"stream": "stderr", "line": "+  } else {"}
{"stream": "stderr", "line": "+    elements.branchSelect.value = state.selectedBranch.name;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function renderCreateBranchControls("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  const branchName = elements.createBranchInput.value.trim();"}
{"stream": "stderr", "line": "+  const branchAlreadyExists = state.branches.some((branch) => branch.name === branchName);"}
{"stream": "stderr", "line": "+  const canCreate ="}
{"stream": "stderr", "line": "+    state.selectedRepository !== null &&"}
{"stream": "stderr", "line": "+    !state.loadingBranches &&"}
{"stream": "stderr", "line": "+    !state.creatingBranch &&"}
{"stream": "stderr", "line": "+    state.branches.length > 0 &&"}
{"stream": "stderr", "line": "+    branchName.length > 0 &&"}
{"stream": "stderr", "line": "+    !branchAlreadyExists;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.createBranchInput.disabled ="}
{"stream": "stderr", "line": "+    state.selectedRepository === null || state.loadingBranches || state.creatingBranch;"}
{"stream": "stderr", "line": "+  elements.createBranchButton.disabled = !canCreate;"}
{"stream": "stderr", "line": "+  elements.createBranchButton.textContent = state.creatingBranch"}
{"stream": "stderr", "line": "+    ? \"Creating...\""}
{"stream": "stderr", "line": "+    : \"Create branch\";"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if ("}
{"stream": "stderr", "line": "+    branchName.length > 0 &&"}
{"stream": "stderr", "line": "+    branchAlreadyExists &&"}
{"stream": "stderr", "line": "+    state.createBranchMessage.text.length === 0"}
{"stream": "stderr", "line": "+  ) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Branch already exists. Select it from the branch picker.\","}
{"stream": "stderr", "line": "+      tone: \"warning\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function renderConnectionStatus("}
{"stream": "stderr", "line": "+  element: HTMLDivElement,"}
{"stream": "stderr", "line": "+  status: ConnectionStatus"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  const view = getConnectionStatusView(status);"}
{"stream": "stderr", "line": "+  element.className = `status-box ${view.tone}`;"}
{"stream": "stderr", "line": "+  element.textContent = view.detail === null ? view.label : `${view.label}. ${view.detail}`;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function renderInlineMessage(element: HTMLParagraphElement, message: InlineMessage): void {"}
{"stream": "stderr", "line": "+  element.className = `field-message ${message.tone === \"neutral\" ? \"\" : message.tone}`.trim();"}
{"stream": "stderr", "line": "+  element.textContent = message.text;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function collectElements(): OptionsElements {"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    form: requireElement(\"options-form\", HTMLFormElement),"}
{"stream": "stderr", "line": "+    status: requireElement(\"options-status\", HTMLParagraphElement),"}
{"stream": "stderr", "line": "+    patInput: requireElement(\"github-pat\", HTMLInputElement),"}
{"stream": "stderr", "line": "+    togglePatButton: requireElement(\"toggle-pat\", HTMLButtonElement),"}
{"stream": "stderr", "line": "+    patError: requireElement(\"pat-error\", HTMLParagraphElement),"}
{"stream": "stderr", "line": "+    loadRepositoriesButton: requireElement(\"load-repositories\", HTMLButtonElement),"}
{"stream": "stderr", "line": "+    repositorySearchInput: requireElement(\"repository-search\", HTMLInputElement),"}
{"stream": "stderr", "line": "+    repositorySelect: requireElement(\"repository-select\", HTMLSelectElement),"}
{"stream": "stderr", "line": "+    repositoryStatus: requireElement(\"repository-status\", HTMLParagraphElement),"}
{"stream": "stderr", "line": "+    branchSelect: requireElement(\"branch-select\", HTMLSelectElement),"}
{"stream": "stderr", "line": "+    branchStatus: requireElement(\"branch-status\", HTMLParagraphElement),"}
{"stream": "stderr", "line": "+    createBranchInput: requireElement(\"create-branch-name\", HTMLInputElement),"}
{"stream": "stderr", "line": "+    createBranchButton: requireElement(\"create-branch\", HTMLButtonElement),"}
{"stream": "stderr", "line": "+    createBranchStatus: requireElement(\"create-branch-status\", HTMLParagraphElement),"}
{"stream": "stderr", "line": "+    autoSyncCheckbox: requireElement(\"auto-sync-enabled\", HTMLInputElement),"}
{"stream": "stderr", "line": "+    testConnectionButton: requireElement(\"test-connection\", HTMLButtonElement),"}
{"stream": "stderr", "line": "+    connectionStatusBox: requireElement(\"connection-status\", HTMLDivElement),"}
{"stream": "stderr", "line": "+    saveButton: requireElement(\"save-settings\", HTMLButtonElement),"}
{"stream": "stderr", "line": "+    saveStatus: requireElement(\"save-status\", HTMLParagraphElement)"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function requireElement<T extends HTMLElement>("}
{"stream": "stderr", "line": "+  id: string,"}
{"stream": "stderr", "line": "+  constructor: { new (...args: never[]): T }"}
{"stream": "stderr", "line": "+): T {"}
{"stream": "stderr", "line": "+  const element = document.getElementById(id);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!(element instanceof constructor)) {"}
{"stream": "stderr", "line": "+    throw new Error(`Missing options element: ${id}`);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return element;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function readSettings(): Promise<SettingsState> {"}
{"stream": "stderr", "line": "+  const values = await chrome.storage.local.get([STORAGE_KEYS.settings]);"}
{"stream": "stderr", "line": "+  const value = values[STORAGE_KEYS.settings];"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return isSettingsState(value) ? value : DEFAULT_SETTINGS_STATE;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function saveSettings("}
{"stream": "stderr", "line": "+  update: Partial<Omit<SettingsState, \"version\" | \"updatedAt\">>"}
{"stream": "stderr", "line": "+): Promise<SettingsState> {"}
{"stream": "stderr", "line": "+  const current = await readSettings();"}
{"stream": "stderr", "line": "+  const next: SettingsState = {"}
{"stream": "stderr", "line": "+    ...current,"}
{"stream": "stderr", "line": "+    ...update,"}
{"stream": "stderr", "line": "+    version: STORAGE_SCHEMA_VERSION,"}
{"stream": "stderr", "line": "+    updatedAt: new Date().toISOString()"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  await chrome.storage.local.set({"}
{"stream": "stderr", "line": "+    [STORAGE_KEYS.settings]: next"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return next;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function sendRuntimeMessage<T>(message: RuntimeMessage): Promise<RuntimeResponse<T>> {"}
{"stream": "stderr", "line": "+  return new Promise((resolve) => {"}
{"stream": "stderr", "line": "+    chrome.runtime.sendMessage(message, (response: RuntimeResponse<T> | undefined) => {"}
{"stream": "stderr", "line": "+      const lastError = chrome.runtime.lastError;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (lastError !== undefined) {"}
{"stream": "stderr", "line": "+        resolve({"}
{"stream": "stderr", "line": "+          ok: false,"}
{"stream": "stderr", "line": "+          error: normalizeError(new Error(lastError.message))"}
{"stream": "stderr", "line": "+        });"}
{"stream": "stderr", "line": "+        return;"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (response === undefined) {"}
{"stream": "stderr", "line": "+        resolve({"}
{"stream": "stderr", "line": "+          ok: false,"}
{"stream": "stderr", "line": "+          error: normalizeError(new Error(\"Background service worker did not respond.\"))"}
{"stream": "stderr", "line": "+        });"}
{"stream": "stderr", "line": "+        return;"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      resolve(response);"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function normalizePat(value: string): string | null {"}
{"stream": "stderr", "line": "+  const trimmed = value.trim();"}
{"stream": "stderr", "line": "+  return trimmed.length === 0 ? null : trimmed;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function createConnectionStatus("}
{"stream": "stderr", "line": "+  code: ConnectionStatusCode,"}
{"stream": "stderr", "line": "+  error: NormalizedError | null = null,"}
{"stream": "stderr", "line": "+  checkedAt: IsoDateString | null = new Date().toISOString()"}
{"stream": "stderr", "line": "+): ConnectionStatus {"}
{"stream": "stderr", "line": "+  return {"}
{"stream": "stderr", "line": "+    code,"}
{"stream": "stderr", "line": "+    checkedAt,"}
{"stream": "stderr", "line": "+    error"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function mergeRepositories("}
{"stream": "stderr", "line": "+  repositories: RepositoryRef[],"}
{"stream": "stderr", "line": "+  additional: RepositoryRef[]"}
{"stream": "stderr", "line": "+): RepositoryRef[] {"}
{"stream": "stderr", "line": "+  const byFullName = new Map<string, RepositoryRef>();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  for (const repository of [...repositories, ...additional]) {"}
{"stream": "stderr", "line": "+    byFullName.set(repository.fullName, repository);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return [...byFullName.values()].sort((left, right) =>"}
{"stream": "stderr", "line": "+    left.fullName.localeCompare(right.fullName)"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function mergeBranches(branches: BranchRef[], additional: BranchRef[]): BranchRef[] {"}
{"stream": "stderr", "line": "+  const byName = new Map<string, BranchRef>();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  for (const branch of [...branches, ...additional]) {"}
{"stream": "stderr", "line": "+    byName.set(branch.name, branch);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return [...byName.values()].sort((left, right) => left.name.localeCompare(right.name));"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+if (typeof document !== \"undefined\") {"}
{"stream": "stderr", "line": "+  void initOptionsPage();"}
{"stream": "stderr", "line": "+}"}
