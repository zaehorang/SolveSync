{"stream": "stderr", "line": "+async function readSettings(): Promise<SettingsState> {"}
{"stream": "stderr", "line": "+  const values = await chrome.storage.local.get([STORAGE_KEYS.settings]);"}
{"stream": "stderr", "line": "+  const value = values[STORAGE_KEYS.settings];"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return isSettingsState(value) ? value : DEFAULT_SETTINGS_STATE;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+async function saveSettings("}
{"stream": "stderr", "line": "+  update: Partial<Omit<SettingsState, \"version\" | \"updatedAt\">>"}
{"stream": "stderr", "line": "+): Promise<SettingsState> {"}
{"stream": "stderr", "line": "+  const current = await readSettings();"}
{"stream": "stderr", "line": "+  const next: SettingsState = {"}
{"stream": "stderr", "line": "+    ...current,"}
{"stream": "stderr", "line": "+    ...update,"}
{"stream": "stderr", "line": "+    version: STORAGE_SCHEMA_VERSION,"}
{"stream": "stderr", "line": "+    updatedAt: new Date().toISOString()"}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  await chrome.storage.local.set({"}
{"stream": "stderr", "line": "+    [STORAGE_KEYS.settings]: next"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return next;"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function sendRuntimeMessage<T>(message: RuntimeMessage): Promise<RuntimeResponse<T>> {"}
{"stream": "stderr", "line": "+  return new Promise((resolve) => {"}
{"stream": "stderr", "line": "+    chrome.runtime.sendMessage(message, (response: RuntimeResponse<T> | undefined) => {"}
{"stream": "stderr", "line": "+      const lastError = chrome.runtime.lastError;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (lastError !== undefined) {"}
{"stream": "stderr", "line": "+        resolve({"}
{"stream": "stderr", "line": "+          ok: false,"}
{"stream": "stderr", "line": "+          error: normalizeError(new Error(lastError.message))"}
{"stream": "stderr", "line": "+        });"}
{"stream": "stderr", "line": "+        return;"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      if (response === undefined) {"}
{"stream": "stderr", "line": "+        resolve({"}
{"stream": "stderr", "line": "+          ok: false,"}
{"stream": "stderr", "line": "+          error: normalizeError(new Error(\"Background service worker did not respond.\"))"}
{"stream": "stderr", "line": "+        });"}
{"stream": "stderr", "line": "+        return;"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+      resolve(response);"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  });"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function normalizePat(value: string): string | null {"}
{"stream": "stderr", "line": "+  const trimmed = value.trim();"}
{"stream": "stderr", "line": "+  return trimmed.length === 0 ? null : trimmed;"}
{"stream": "stderr", "line": "+}"}
