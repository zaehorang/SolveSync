{"stream": "stderr", "line": "+function mergeRepositories("}
{"stream": "stderr", "line": "+  repositories: RepositoryRef[],"}
{"stream": "stderr", "line": "+  additional: RepositoryRef[]"}
{"stream": "stderr", "line": "+): RepositoryRef[] {"}
{"stream": "stderr", "line": "+  const byFullName = new Map<string, RepositoryRef>();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  for (const repository of [...repositories, ...additional]) {"}
{"stream": "stderr", "line": "+    byFullName.set(repository.fullName, repository);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return [...byFullName.values()].sort((left, right) =>"}
{"stream": "stderr", "line": "+    left.fullName.localeCompare(right.fullName)"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+}"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+function mergeBranches(branches: BranchRef[], additional: BranchRef[]): BranchRef[] {"}
