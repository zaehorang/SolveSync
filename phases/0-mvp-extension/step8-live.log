{"stream": "stderr", "line": "+function requireElement<T extends HTMLElement>("}
{"stream": "stderr", "line": "+  id: string,"}
{"stream": "stderr", "line": "+  constructor: { new (...args: never[]): T }"}
{"stream": "stderr", "line": "+): T {"}
{"stream": "stderr", "line": "+  const element = document.getElementById(id);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (!(element instanceof constructor)) {"}
{"stream": "stderr", "line": "+    throw new Error(`Missing options element: ${id}`);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  return element;"}
{"stream": "stderr", "line": "+}"}
