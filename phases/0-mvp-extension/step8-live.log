{"stream": "stderr", "line": "+function renderRepositorySelect("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): void {"}
{"stream": "stderr", "line": "+  const filterState = getRepositoryFilterState("}
{"stream": "stderr", "line": "+    state.repositories,"}
{"stream": "stderr", "line": "+    state.repositoryQuery"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  elements.repositorySelect.replaceChildren("}
{"stream": "stderr", "line": "+    ...filterState.visibleRepositories.map((repository) => {"}
{"stream": "stderr", "line": "+      const option = document.createElement(\"option\");"}
{"stream": "stderr", "line": "+      option.value = repository.fullName;"}
{"stream": "stderr", "line": "+      option.textContent = `${repository.fullName}${repository.private ? \" (private)\" : \"\"}`;"}
{"stream": "stderr", "line": "+      return option;"}
{"stream": "stderr", "line": "+    })"}
{"stream": "stderr", "line": "+  );"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.selectedRepository === null) {"}
{"stream": "stderr", "line": "+    elements.repositorySelect.selectedIndex = -1;"}
{"stream": "stderr", "line": "+  } else {"}
{"stream": "stderr", "line": "+    elements.repositorySelect.value = state.selectedRepository.fullName;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (elements.repositorySelect.value !== state.selectedRepository.fullName) {"}
{"stream": "stderr", "line": "+      elements.repositorySelect.selectedIndex = -1;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if ("}
{"stream": "stderr", "line": "+    state.repositories.length > 0 &&"}
{"stream": "stderr", "line": "+    !filterState.hasMatches &&"}
{"stream": "stderr", "line": "+    state.repositoryMessage.tone !== \"error\""}
{"stream": "stderr", "line": "+  ) {"}
{"stream": "stderr", "line": "+    state.repositoryMessage = {"}
{"stream": "stderr", "line": "+      text: \"No repositories match the search.\","}
{"stream": "stderr", "line": "+      tone: \"warning\""}
