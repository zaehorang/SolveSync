{"stream": "stderr", "line": "+async function loadBranches("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState,"}
{"stream": "stderr", "line": "+  repository: RepositoryRef"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  state.loadingBranches = true;"}
{"stream": "stderr", "line": "+  state.branchMessage = {"}
{"stream": "stderr", "line": "+    text: \"Loading branches...\","}
{"stream": "stderr", "line": "+    tone: \"neutral\""}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<BranchRef[]>({"}
{"stream": "stderr", "line": "+      type: \"github:branches:list\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        repository"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.branches = response.data;"}
{"stream": "stderr", "line": "+    const branchName = getDefaultBranchSelection("}
{"stream": "stderr", "line": "+      repository,"}
{"stream": "stderr", "line": "+      state.branches,"}
{"stream": "stderr", "line": "+      state.selectedBranch?.name ?? null"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.selectedBranch ="}
{"stream": "stderr", "line": "+      branchName === null"}
{"stream": "stderr", "line": "+        ? null"}
{"stream": "stderr", "line": "+        : state.branches.find((branch) => branch.name === branchName) ?? null;"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (state.branches.length === 0) {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: \"No branches found. Empty repositories cannot create a branch from default branch HEAD.\","}
{"stream": "stderr", "line": "+        tone: \"warning\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    } else if (state.selectedBranch?.name === repository.defaultBranch) {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: `Default branch selected: ${repository.defaultBranch}.`,"}
{"stream": "stderr", "line": "+        tone: \"success\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    } else {"}
{"stream": "stderr", "line": "+      state.branchMessage = {"}
{"stream": "stderr", "line": "+        text: `Loaded ${state.branches.length} branches.`,"}
{"stream": "stderr", "line": "+        tone: \"success\""}
{"stream": "stderr", "line": "+      };"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.branchMessage = {"}
{"stream": "stderr", "line": "+      text: normalized.userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.loadingBranches = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
