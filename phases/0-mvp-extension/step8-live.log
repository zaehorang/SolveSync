{"stream": "stderr", "line": "+async function createBranch("}
{"stream": "stderr", "line": "+  elements: OptionsElements,"}
{"stream": "stderr", "line": "+  state: OptionsRuntimeState"}
{"stream": "stderr", "line": "+): Promise<void> {"}
{"stream": "stderr", "line": "+  const branchName = elements.createBranchInput.value.trim();"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.selectedRepository === null) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Choose a repository before creating a branch.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (branchName.length === 0) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Enter a branch name.\","}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  if (state.branches.some((branch) => branch.name === branchName)) {"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: \"Branch already exists. Select it from the branch picker.\","}
{"stream": "stderr", "line": "+      tone: \"warning\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+    return;"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  state.creatingBranch = true;"}
{"stream": "stderr", "line": "+  state.createBranchMessage = {"}
{"stream": "stderr", "line": "+    text: \"Creating branch...\","}
{"stream": "stderr", "line": "+    tone: \"neutral\""}
{"stream": "stderr", "line": "+  };"}
{"stream": "stderr", "line": "+  render(elements, state);"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+  try {"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput)"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    const response = await sendRuntimeMessage<BranchRef>({"}
{"stream": "stderr", "line": "+      type: \"github:branch:create\","}
{"stream": "stderr", "line": "+      payload: {"}
{"stream": "stderr", "line": "+        repository: state.selectedRepository,"}
{"stream": "stderr", "line": "+        branchName"}
{"stream": "stderr", "line": "+      }"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    if (!response.ok) {"}
{"stream": "stderr", "line": "+      throw response.error;"}
{"stream": "stderr", "line": "+    }"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    state.branches = mergeBranches(state.branches, [response.data]);"}
{"stream": "stderr", "line": "+    state.selectedBranch = response.data;"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus(\"branch_created\");"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: `Created branch ${response.data.name}.`,"}
{"stream": "stderr", "line": "+      tone: \"success\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    elements.createBranchInput.value = \"\";"}
{"stream": "stderr", "line": "+"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      githubPat: normalizePat(state.githubPatInput),"}
{"stream": "stderr", "line": "+      selectedRepository: state.selectedRepository,"}
{"stream": "stderr", "line": "+      selectedBranch: state.selectedBranch,"}
{"stream": "stderr", "line": "+      autoSyncEnabled: state.autoSyncEnabled,"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } catch (error) {"}
{"stream": "stderr", "line": "+    const normalized = normalizeError(error);"}
{"stream": "stderr", "line": "+    state.connectionStatus = createConnectionStatus("}
{"stream": "stderr", "line": "+      mapConnectionErrorCode(normalized.code),"}
{"stream": "stderr", "line": "+      normalized"}
{"stream": "stderr", "line": "+    );"}
{"stream": "stderr", "line": "+    state.createBranchMessage = {"}
{"stream": "stderr", "line": "+      text: normalized.userMessage,"}
{"stream": "stderr", "line": "+      tone: \"error\""}
{"stream": "stderr", "line": "+    };"}
{"stream": "stderr", "line": "+    await saveSettings({"}
{"stream": "stderr", "line": "+      connectionStatus: state.connectionStatus"}
{"stream": "stderr", "line": "+    });"}
{"stream": "stderr", "line": "+  } finally {"}
{"stream": "stderr", "line": "+    state.creatingBranch = false;"}
{"stream": "stderr", "line": "+    render(elements, state);"}
{"stream": "stderr", "line": "+  }"}
{"stream": "stderr", "line": "+}"}
