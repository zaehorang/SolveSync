{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$ROOT/.codex/hooks/tdd-guard.sh\"",
            "timeout": 30,
            "statusMessage": "Checking TDD guard"
          }
        ]
      },
      {
        "matcher": "Shell|Bash|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$ROOT/.codex/hooks/commit-guard.sh\"",
            "timeout": 600,
            "statusMessage": "Checking commit guard"
          }
        ]
      }
    ]
  }
}
